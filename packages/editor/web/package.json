{
  "name": "@schema-form/editor-web",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "author": "yangdongnan",
  "description": "Schema 驱动的可视化自由布局编辑器",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:widgets": "vite build --config vite.widget.config.ts",
    "build:microapp": "vite build --config vite.microapp.config.ts",
    "build:micro-app": "vite build --config vite.micro-app.config.ts",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@micro-zoe/micro-app": "1.0.0-rc.30",
    "@schema-form/micro-app": "workspace:*",
    "@schema-form/socket": "workspace:*",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "axios": "^1.16.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.9.7",
    "html-to-image": "^1.11.13",
    "jsonpath-plus": "^10.4.0",
    "pinia": "^2.3.0",
    "pinyin-pro": "^3.28.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@schema-form/shared-config": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "sass": "^1.99.0",
    "typescript": "~5.7.3",
    "vite": "^6.3.2",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.8"
  }
}
