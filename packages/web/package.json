{
  "name": "@schema-form/web",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.16.0",
    "element-plus": "^2.9.7",
    "pinia": "^2.3.0",
    "qiankun": "^2.10.16",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.27.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "sass": "^1.99.0",
    "typescript": "~5.7.3",
    "vite": "^6.3.2",
    "vite-plugin-qiankun": "^1.0.15",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.8"
  }
}
