{
  "name": "schema-form-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "yangdongnan",
  "description": "Schema 驱动的可视化自由布局设计器与渲染器 — 支持 qiankun 微前端接入与 microapp 下层集成",
  "scripts": {
    "dev": "pnpm dev:server & sleep 3 && pnpm dev:web",
    "dev:server": "pnpm --filter @schema-form/server dev",
    "dev:web": "pnpm --parallel --filter @schema-form/editor-web --filter @schema-form/flow-web dev",
    "dev:editor": "pnpm --filter @schema-form/editor-web dev",
    "dev:flow": "pnpm --filter @schema-form/flow-web dev",
    "dev:portal": "pnpm --filter @schema-form/portal dev",
    "dev:all": "pnpm dev:server & sleep 3 && pnpm --parallel --filter @schema-form/editor-web --filter @schema-form/flow-web --filter @schema-form/portal dev",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @schema-form/server build",
    "build:editor": "pnpm --filter @schema-form/editor-web build",
    "build:flow": "pnpm --filter @schema-form/flow-web build",
    "build:portal": "pnpm --filter @schema-form/portal build",
    "vercel-build": "pnpm build:server && pnpm build:editor && pnpm build:flow && pnpm build:portal && mkdir -p packages/portal/dist/editor && cp -r packages/editor/web/dist/* packages/portal/dist/editor/ && mkdir -p packages/portal/dist/flow && cp -r packages/flow/web/dist/* packages/portal/dist/flow/",
    "db:up": "pnpm --filter @schema-form/server db:up",
    "db:down": "pnpm --filter @schema-form/server db:down",
    "db:seed": "pnpm --filter @schema-form/server db:seed",
    "format": "pnpm -r format",
    "clean": "pnpm -r exec -- rm -rf node_modules dist .turbo"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
