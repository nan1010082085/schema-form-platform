{
  "name": "schema-form-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "yangdongnan",
  "description": "Schema 驱动的可视化自由布局设计器与渲染器 — 支持 qiankun 微前端接入与 microapp 下层集成",
  "scripts": {
    "extract:ai-metadata": "npx tsx scripts/extract-ai-metadata.ts",
    "dev": "bash scripts/kill-ports.sh && pnpm dev:server & sleep 3 && pnpm --parallel --filter @schema-form/editor-web --filter @schema-form/flow-web --filter @schema-form/ai-app --filter @schema-form/portal dev",
    "dev:server": "lsof -ti :3001 | xargs kill -9 2>/dev/null; pnpm extract:ai-metadata && pnpm --filter @schema-form/server dev",
    "dev:web": "pnpm --parallel --filter @schema-form/editor-web --filter @schema-form/flow-web --filter @schema-form/ai-app dev",
    "dev:editor": "pnpm --filter @schema-form/editor-web dev",
    "dev:flow": "pnpm --filter @schema-form/flow-web dev",
    "dev:portal": "pnpm --filter @schema-form/portal dev",
    "dev:ai": "pnpm --filter @schema-form/ai-app dev",
    "kill-ports": "bash scripts/kill-ports.sh",
    "build": "pnpm -r build",
    "build:server": "pnpm extract:ai-metadata && pnpm --filter @schema-form/server build",
    "build:editor": "pnpm --filter @schema-form/editor-web build",
    "build:flow": "pnpm --filter @schema-form/flow-web build",
    "build:portal": "pnpm --filter @schema-form/portal build",
    "build:ai": "pnpm --filter @schema-form/ai-app build",
    "db:up": "pnpm --filter @schema-form/server db:up",
    "db:down": "pnpm --filter @schema-form/server db:down",
    "db:seed": "pnpm --filter @schema-form/server db:seed",
    "deploy:pack": "bash deploy/pack.sh",
    "deploy:run": "bash deploy/deploy.sh",
    "format": "pnpm -r format",
    "clean": "pnpm -r exec -- rm -rf node_modules dist .turbo"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
