{
  "name": "schema-form-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "yangdongnan",
  "description": "Schema 驱动的低代码表单引擎与流程引擎 — 可视化设计器 + BPMN 流程编排 + AI 对话式生成 + SaaS Workflow",
  "scripts": {
    "extract:ai-metadata": "pnpm --filter @schema-form/server exec tsx ../../scripts/extract-ai-metadata.ts",
    "dev": "bash scripts/kill-ports.sh && pnpm dev:server & bash scripts/wait-for-server.sh && pnpm dev:web",
    "dev:server": "lsof -ti :3001 | xargs kill -9 2>/dev/null; pnpm extract:ai-metadata && no_proxy='*' pnpm --filter @schema-form/server dev",
    "dev:web": "no_proxy='*' pnpm --parallel --filter @schema-form/shell --filter @schema-form/editor-web --filter @schema-form/flow-web --filter @schema-form/ai-app --filter @schema-form/admin dev",
    "dev:shell": "no_proxy='*' pnpm --filter @schema-form/shell dev",
    "dev:editor": "no_proxy='*' pnpm --filter @schema-form/editor-web dev",
    "dev:flow": "no_proxy='*' pnpm --filter @schema-form/flow-web dev",
    "dev:ai": "no_proxy='*' pnpm --filter @schema-form/ai-app dev",
    "dev:admin": "no_proxy='*' pnpm --filter @schema-form/admin dev",
    "kill-ports": "bash scripts/kill-ports.sh",
    "build": "pnpm -r build",
    "build:server": "pnpm extract:ai-metadata && pnpm --filter @schema-form/server build",
    "build:shell": "pnpm --filter @schema-form/shell build",
    "build:editor": "pnpm --filter @schema-form/editor-web build",
    "build:flow": "pnpm --filter @schema-form/flow-web build",
    "build:ai": "pnpm --filter @schema-form/ai-app build",
    "build:admin": "pnpm --filter @schema-form/admin build",
    "db:up": "pnpm --filter @schema-form/server db:up",
    "db:down": "pnpm --filter @schema-form/server db:down",
    "db:seed": "pnpm --filter @schema-form/server db:seed",
    "deploy:pack": "bash deploy/pack.sh",
    "deploy:run": "bash deploy/deploy.sh",
    "format": "pnpm -r format",
    "clean": "pnpm -r exec -- rm -rf node_modules dist .turbo",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@iconify-icons/ep": "^1.2.12",
    "@iconify/vue": "^5.0.1",
    "tdesign-icons-vue-next": "^0.4.4",
    "tdesign-vue-next": "^1.20.1"
  }
}
